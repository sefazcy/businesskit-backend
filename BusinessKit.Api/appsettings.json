{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=businesskit.db"
  },
  // IMPORTANT: JwtSettings:SecretKey below is a development-only placeholder.
  // In production, override this via environment variables or user secrets.
  // Never commit a real secret key to source control.
  "JwtSettings": {
    "SecretKey": "dev-only-secret-key-change-in-production-min-32-chars!",
    "Issuer": "BusinessKit",
    "Audience": "BusinessKitClients",
    "ExpirationInMinutes": 60
  },
  // Active payment provider. Supported values: "Manual".
  // "Iyzico" will be supported in v5.8. Setting an unsupported value causes checkout to fail clearly.
  "PaymentProvider": {
    "ActiveProvider": "Manual"
  },
  // IMPORTANT: EmailSettings:Password must be set via environment variable in production (EmailSettings__Password).
  // Keep Enabled=false to disable all email in development. App starts and works without any SMTP config.
  "EmailSettings": {
    "Enabled": false,
    "Host": "",
    "Port": 587,
    "UseSsl": true,
    "Username": "",
    "Password": "",
    "FromEmail": "",
    "FromName": "",
    "AdminEmail": ""
  }
}
